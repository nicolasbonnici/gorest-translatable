{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "groupName": "all go deps",
      "matchManagers": [
        "gomod"
      ],
      "automerge": true
    }
  ],
  "automerge": true,
  "automergeType": "pr",
  "postUpdateOptions": [
    "gomodTidy"
  ]
}
